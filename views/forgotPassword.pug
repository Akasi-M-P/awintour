extends base

block content
  main.main.main--auth
    .auth-card
      .auth-card__logo
        span.logo-text awintour
      h2.auth-card__title Forgot your password?
      p.auth-card__subtitle Enter your email and we'll send you a reset link.
      form.form.form--forgot-password
        .form__group
          label.form__label(for='email') Email address
          input#email.form__input(type='email', placeholder='you@example.com', required)
        .form__group
          button.btn.btn--green.btn--full Send reset link
      p.auth-card__link Remember your password? #[a(href='/login') Log in]
