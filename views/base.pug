doctype html
html(lang="en")
  head
    block head
      meta(charset="UTF-8")
      meta(name="viewport", content="width=device-width, initial-scale=1.0")

      script(src="https://js.stripe.com/v3/")
      link(href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=Open+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap", rel="stylesheet")
      link(rel="stylesheet", href="/css/style.css")
      link(rel="shortcut icon", href="/img/favicon.png", type="image/png")
      title awintour | #{title}

  body
    // HEADER
    include _header

    // MAIN CONTENT
    block content
     h1 Default Page

    // FOOTER
    include _footer

    // Logout confirmation modal
    #logout-modal.logout-modal(role='dialog' aria-modal='true' aria-labelledby='logout-modal-title')
      .logout-modal__backdrop
      .logout-modal__card
        .logout-modal__icon
          svg(aria-hidden='true')
            use(xlink:href='/img/icons.svg#icon-log-out')
        h3#logout-modal-title.logout-modal__title Sign out?
        p.logout-modal__body You'll be signed out of your account on this device.
        .logout-modal__actions
          button#logout-cancel.logout-modal__btn.logout-modal__btn--cancel Cancel
          button#logout-confirm.logout-modal__btn.logout-modal__btn--confirm Sign out

    //- script(src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js")
    //- script(src="/js/mapbox.js") 
    //- script(src="/js/login.js") 
    script(src="/js/bundle.js") 
