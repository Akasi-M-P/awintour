extends base

block content
  main.main
    .user-view
      - const activeSection = 'manage-reviews'
      include _accountNav

      .user-view__content
        .user-view__form-container.user-view__form-container--wide
          .admin-header
            h2.heading-secondary Manage Reviews
          if !reviews || reviews.length === 0
            p.no-results No reviews found.
          else
            .admin-table-wrap
              table.admin-table.admin-table--reviews
                thead
                  tr
                    th User
                    th Tour
                    th Rating
                    th Review
                    th Actions
                tbody
                  each review in reviews
                    tr
                      td(data-label='User')
                        .admin-user-cell
                          img.admin-table__img.admin-table__img--round(src=`/img/users/${review.user.photo}` alt=review.user.name)
                          span= review.user.name
                      td(data-label='Tour')= review.tour ? review.tour.name : '—'
                      td(data-label='Rating')= review.rating
                      td.admin-table__review(data-label='Review')= review.review
                      td.admin-table__actions
                        button.admin-icon-btn.admin-icon-btn--delete(
                          data-id=`${review._id}`
                          data-resource='reviews'
                          data-action='delete'
                          title='Delete review'
                          aria-label='Delete review'
                        )
                          svg(aria-hidden='true')
                            use(xlink:href='/img/icons.svg#icon-trash-2')
