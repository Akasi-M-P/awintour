extends base

block content
  main.main
    .user-view
      - const activeSection = 'manage-reviews'
      include _accountNav

      .user-view__content
        .user-view__form-container.user-view__form-container--wide
          .admin-header
            h2.heading-secondary Manage Reviews
          if !reviews || reviews.length === 0
            p.no-results No reviews found.
          else
            .admin-table-wrap
              table.admin-table
                thead
                  tr
                    th User
                    th Tour
                    th Rating
                    th Review
                    th Actions
                tbody
                  each review in reviews
                    tr
                      td
                        .admin-user-cell
                          img.admin-table__img.admin-table__img--round(src=`/img/users/${review.user.photo}` alt=review.user.name)
                          span= review.user.name
                      td= review.tour ? review.tour.name : '—'
                      td= review.rating
                      td.admin-table__review= review.review
                      td.admin-table__actions
                        button.btn.btn--small.btn--red(
                          data-id=`${review._id}`
                          data-resource='reviews'
                          data-action='delete'
                        ) Delete
