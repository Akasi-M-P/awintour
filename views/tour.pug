extends base
include _reviewCard

block append head
  script(src='https://api.mapbox.com/mapbox-gl-js/v3.17.0/mapbox-gl.js')
  link(href='https://api.mapbox.com/mapbox-gl-js/v3.17.0/mapbox-gl.css' rel='stylesheet')


mixin overviewBox(label, text, icon)
  .overview-box__detail
    svg.overview-box__icon
      use(xlink:href=`/img/icons.svg#icon-${icon}`)
    span.overview-box__label= label
    span.overview-box__text= text


block content
  section.section-header
    .header__hero
      .header__hero-overlay &nbsp;
      img.header__hero-img(src=`/img/tours/${tour.imageCover}`, alt=`${tour.name}`)

    .heading-box
      h1.heading-primary
        span= `${tour.name}`
      .heading-box__group
        .heading-box__detail
          svg.heading-box__icon
            use(xlink:href='/img/icons.svg#icon-clock')
          span.heading-box__text= `${tour.duration} days`
        .heading-box__detail
          svg.heading-box__icon
            use(xlink:href='/img/icons.svg#icon-map-pin')
          span.heading-box__text= tour.startLocation.description

  section.section-description
    .overview-box
      div
        .overview-box__group
          h2.heading-secondary.ma-bt-lg Quick facts

          - const date = tour.startDates[0].toLocaleString('en-US', { month: 'long', year: 'numeric' });
          +overviewBox('Next date', date, 'calendar')
          +overviewBox('Difficulty', tour.difficulty, 'trending-up')
          +overviewBox('Participants', `${tour.maxGroupSize} people`, 'user')
          +overviewBox('Rating', `${tour.ratingsAverage} / 5`, 'star')

          .overview-box__detail
            svg.overview-box__icon
              use(xlink:href='/img/icons.svg#icon-users')
            span.overview-box__label Availability
            .capacity-bar
              .capacity-bar__fill(style=`width:${Math.round((seatsLeft / tour.maxGroupSize) * 100)}%`)
            span.overview-box__text= `${seatsLeft} / ${tour.maxGroupSize} spots left`

        .overview-box__group
          h2.heading-secondary.ma-bt-lg Your tour guides

          each guide in tour.guides
            .overview-box__detail
              img.overview-box__img(src=`/img/users/${guide.photo}`, alt=`${guide.name}`)
              if guide.role === 'lead-guide'
                span.overview-box__label Lead guide
              else if guide.role === 'guide'
                span.overview-box__label Tour guide
              else if guide.role === 'intern'
                span.overview-box__label Intern
              span.overview-box__text= guide.name

        .overview-box__group
          h2.heading-secondary.ma-bt-lg Available dates
          .dates-grid
            each d in tour.startDates
              .date-chip
                svg.date-chip__icon
                  use(xlink:href='/img/icons.svg#icon-calendar')
                span= new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })

    .description-box
      h2.heading-secondary.ma-bt-lg= `About ${tour.name}`
      - const paragraphs = tour.description ? tour.description.split('\n') : [];
      each paragraph in paragraphs
        p.description__text= paragraph

  section.section-pictures
    each img, i in tour.images
      .picture-box
        img.picture-box__img(src=`/img/tours/${img}`, alt=`${tour.name} ${i + 1}`, class=`picture-box__img--${i + 1}`)

  section.section-map
    #map(data-locations=`${JSON.stringify(tour.locations)}`)

  section.section-reviews
    .reviews
      each review in tour.reviews
        .review-wrapper(data-review-id=`${review._id}`)
          +reviewCard(review)
          if user && review.user._id.equals(user._id)
            .review-owner-actions
              button.btn.btn--small.btn--green(
                data-review-id=`${review._id}`
                data-rating=`${review.rating}`
                data-text=`${review.review}`
                data-tour-id=`${tour._id}`
                data-action='edit-review'
              ) Edit
              button.btn.btn--small.btn--red(
                data-review-id=`${review._id}`
                data-action='delete-review'
              ) Delete

    if user && hasBooked && !userReview
      .review-form-section
        h3.review-form__title Share your experience
        form.form.review-form(data-tour-id=`${tour._id}`)
          .star-rating
            each val in [5,4,3,2,1]
              input(type='radio' name='rating' id=`star${val}` value=`${val}`)
              label(for=`star${val}`)
                svg(viewBox='0 0 24 24')
                  use(xlink:href='/img/icons.svg#icon-star')
          .form__group
            label.form__label(for='review') Your review
            textarea#review.form__input(rows='4' placeholder='Tell us about your experience…' required)
          button.btn.btn--green Submit review

    else if user && !hasBooked
      .review-cta
        p.review-cta__text Book this tour to leave a review.

  section.section-cta
    .cta
      .cta__img.cta__img--logo
        span.logo-text awintour
      img.cta__img.cta__img--1(src=`/img/tours/${tour.images[1]}`, alt='Tour picture 1')
      img.cta__img.cta__img--2(src=`/img/tours/${tour.images[2]}`, alt='Tour picture 2')
      .cta__content
        h2.heading-secondary What are you waiting for?
        p.cta__text= `${tour.duration} days. 1 adventure. Infinite memories. Make it yours today!`
        if user && user.role === 'admin'
          .admin-book-section
            p.admin-book-notice You are logged in as admin — use this form to book on behalf of a user.
            .admin-book-form(data-tour-id=`${tour._id}`)
              .form__group
                label.form__label(for='admin-book-email') User email address
                input#admin-book-email.form__input(type='email' placeholder='user@example.com' required)
              button.btn.btn--green#admin-book-btn Book for user
        else if seatsLeft === 0
          p.cta__sold-out Sold out — no spots remaining.
        else if user
          button.btn.btn--green.span-all-rows#book-tour(data-tour-id=`${tour._id}`)
            | Book tour now!
            span.cta__seats  (#{seatsLeft} spots left)
        else
          a.btn.btn--green.span-all-rows(href='/login') Log in to book tour

  //- Inline edit modal for reviews
  .review-edit-modal
    .review-edit-modal__backdrop
    .review-edit-modal__box
      h3.review-edit-modal__title Edit your review
      .star-rating
        each val in [5,4,3,2,1]
          input(type='radio' name='edit-rating' id=`edit-star${val}` value=`${val}`)
          label(for=`edit-star${val}`)
            svg(viewBox='0 0 24 24')
              use(xlink:href='/img/icons.svg#icon-star')
      textarea#edit-review-text.form__input(rows='4' placeholder='Your review…')
      .review-edit-modal__btns
        button.btn.btn--green#confirm-edit Save changes
        button.btn.btn--white#cancel-edit Cancel
