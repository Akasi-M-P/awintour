extends base

block content
  main.main.main--auth
    .auth-card
      .auth-card__logo
        span.logo-text awintour
      h2.auth-card__title Set a new password
      form.form.form--reset-password(data-token=token)
        .form__group
          label.form__label(for='password') New password
          input#password.form__input(type='password', placeholder='••••••••', required, minlength='8')
        .form__group
          label.form__label(for='passwordConfirm') Confirm new password
          input#passwordConfirm.form__input(type='password', placeholder='••••••••', required, minlength='8')
        .form__group
          button.btn.btn--green.btn--full Reset password
      p.auth-card__link Remembered it? #[a(href='/login') Log in]
