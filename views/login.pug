extends base

block content
  main.main.main--auth
    .auth-card
      .auth-card__logo
        span.logo-text awintour
      h2.auth-card__title Log in to your account
      form.form.form--login
        .form__group
          label.form__label(for='email') Email address
          input#email.form__input(type='email', placeholder='you@example.com', required)
        .form__group
          label.form__label(for='password') Password
          input#password.form__input(type='password', placeholder='••••••••', required, minlength='8')
        .form__group
          button.btn.btn--green.btn--full Log in
      p.auth-card__link Forgot your password? #[a(href='/forgot-password') Reset it]
      p.auth-card__link Don't have an account? #[a(href='/signup') Sign up]
