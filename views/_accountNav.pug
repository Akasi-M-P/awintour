mixin navItem(link, text, icon, isActive)
  li(class= isActive ? 'side-nav--active' : '')
    a(href=link)
      svg
        use(xlink:href=`/img/icons.svg#icon-${icon}`)
      | #{text}

nav.user-view__menu
  ul.side-nav
    +navItem('/me',          'Settings',    'settings',  activeSection === 'settings')
    +navItem('/my-tours',    'My bookings', 'briefcase', activeSection === 'bookings')
    +navItem('/my-reviews',  'My reviews',  'star',      activeSection === 'reviews')
    +navItem('/wishlist',    'Wishlist',    'heart',     activeSection === 'wishlist')

  if user && user.role === 'admin'
    .admin-nav
      h5.admin-nav__heading Admin
      ul.side-nav
        +navItem('/manage-tours',    'Manage tours',    'map',      activeSection === 'manage-tours')
        +navItem('/manage-users',    'Manage users',    'users',    activeSection === 'manage-users')
        +navItem('/manage-reviews',  'Manage reviews',  'star',     activeSection === 'manage-reviews')
        +navItem('/manage-bookings', 'Manage bookings', 'briefcase',activeSection === 'manage-bookings')
