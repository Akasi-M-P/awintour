mixin navItem(link, text, icon, isActive, short)
  li(class= isActive ? 'side-nav--active' : '')
    a(href=link data-short=short || text)
      svg
        use(xlink:href=`/img/icons.svg#icon-${icon}`)
      span.side-nav__label= text

nav.user-view__menu
  ul.side-nav
    +navItem('/me',          'Settings',    'settings',  activeSection === 'settings',  'Settings')
    +navItem('/my-tours',    'My bookings', 'briefcase', activeSection === 'bookings',  'Bookings')
    +navItem('/my-reviews',  'My reviews',  'star',      activeSection === 'reviews',   'Reviews')
    +navItem('/wishlist',    'Wishlist',    'heart',     activeSection === 'wishlist',  'Wishlist')

  if user && user.role === 'admin'
    .admin-nav
      h5.admin-nav__heading Admin
      ul.side-nav
        +navItem('/manage-tours',    'Manage tours',    'map',       activeSection === 'manage-tours',    'Tours')
        +navItem('/manage-users',    'Manage users',    'users',     activeSection === 'manage-users',    'Users')
        +navItem('/manage-reviews',  'Manage reviews',  'star',      activeSection === 'manage-reviews',  'Reviews')
        +navItem('/manage-bookings', 'Manage bookings', 'briefcase', activeSection === 'manage-bookings', 'Bookings')
