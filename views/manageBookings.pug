extends base

block content
  main.main
    .user-view
      - const activeSection = 'manage-bookings'
      include _accountNav

      .user-view__content
        .user-view__form-container.user-view__form-container--wide
          .admin-header
            h2.heading-secondary Manage Bookings
          if !bookings || bookings.length === 0
            p.no-results No bookings found.
          else
            .admin-table-wrap
              table.admin-table.admin-table--bookings
                thead
                  tr
                    th User
                    th Tour
                    th Price
                    th Date
                    th Paid
                    th Actions
                tbody
                  each booking in bookings
                    tr
                      td(data-label='User')= booking.user ? booking.user.name : '—'
                      td(data-label='Tour')= booking.tour ? booking.tour.name : '—'
                      td(data-label='Price') $#{booking.price}
                      td(data-label='Date')= new Date(booking.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
                      td(data-label='Paid')
                        span(class=`admin-badge admin-badge--${booking.paid ? 'yes' : 'no'}`)= booking.paid ? 'Paid' : 'Unpaid'
                      td.admin-table__actions
                        button.admin-icon-btn.admin-icon-btn--delete(
                          data-id=`${booking._id}`
                          data-resource='bookings'
                          data-action='delete'
                          title='Delete booking'
                          aria-label='Delete booking'
                        )
                          svg(aria-hidden='true')
                            use(xlink:href='/img/icons.svg#icon-trash-2')
